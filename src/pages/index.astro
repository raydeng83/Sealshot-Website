---
import SiteLayout from '../layouts/SiteLayout.astro';
import NewsletterForm from '../components/NewsletterForm.astro';
import '@splidejs/splide/css';

const heroSlides = [
  {
    src: '/manual/capture-area.png',
    alt: 'Area capture in progress: selection rectangle, pixel loupe, and live dimensions readout',
    subtitle: 'Capture with precision',
    description: 'A pixel loupe and live dimensions — select exactly what you mean, down to the pixel.',
  },
  {
    src: '/manual/record-prompt.png',
    alt: 'The Record prompt with system audio, microphone, cursor, and countdown options',
    subtitle: 'Record on your terms',
    description: 'Screen, window, or region — with system audio and mic, and a countdown to set the stage.',
  },
  {
    src: '/manual/editor-overview.png',
    alt: 'The Sealshot editor with a capture open: annotation toolbar, canvas, and Info panel',
    subtitle: 'Annotate without damage',
    description: 'Arrows, labels, and blurs stay editable forever; your original pixels are never touched.',
  },
  {
    src: '/manual/redaction-review.png',
    alt: 'Smart Redaction review panel with detected sensitive items pre-checked',
    subtitle: 'Redact with confidence',
    description: 'Smart Redaction finds emails, cards, and keys on device — and covers them for good.',
  },
  {
    src: '/manual/lock-screen.png',
    alt: 'Sealshot locked: captures encrypted on this Mac, unlocking with Touch ID',
    subtitle: "Locked until it's you",
    description: 'Encrypt everything Sealshot stores and unlock with Touch ID. Capturing still works while locked.',
  },
  {
    src: '/manual/extract-data.png',
    alt: 'Extract Structured Data pulling an invoice table out of a screenshot',
    subtitle: 'Data out of pixels',
    description: 'Pull tables and form fields from any screenshot as clean, copyable text — on your Mac.',
  },
  {
    src: '/manual/library-grid.png',
    alt: 'The Library in grid view with OCR full-text search',
    subtitle: 'Find any capture',
    description: 'Search the text inside your screenshots, organized with collections and favorites.',
  },
];

const features = [
  {
    title: 'Capture anything',
    body: 'Area, window, fullscreen, delayed, and scrolling capture with automatic stitching — across all your displays.',
  },
  {
    title: 'Record your screen',
    body: 'Record the screen, a window, or a region with system audio and mic, pause from a floating HUD, export .mov or .mp4.',
  },
  {
    title: 'Redact with confidence',
    body: 'Smart Redaction finds emails, card numbers, IDs, and API keys on device and covers them with unrecoverable solid fill.',
  },
  {
    title: 'Annotate non-destructively',
    body: 'Shapes, arrows, pen, text, numbered badges, shadows — original pixels stay untouched, and undo history survives relaunch.',
  },
  {
    title: 'On-device AI',
    body: 'Automatic titles, summaries, and keywords; extract tables and form fields as clean, copyable text — entirely on your Mac.',
  },
  {
    title: 'Organize and search',
    body: 'Collections, favorites, and OCR full-text search across your library. Share as encrypted .sealshare packages.',
  },
];
---

<SiteLayout
  title="Sealshot — privacy-first screenshots and recordings for Mac"
  description="Capture, record, annotate, and redact with everything processed on device. No account, no telemetry, no cloud."
>
  <section class="hero">
    <div class="wrap">
      <p class="kicker">For macOS 14+</p>
      <h1>Screenshots that keep your secrets</h1>
      <p class="sub">
        Capture, record, annotate, and redact — all processed on your Mac. No
        account. No telemetry. No cloud.
      </p>
      <div class="actions">
        <a class="button" href="/download/">Download for Mac</a>
        <a class="button secondary" href="/docs/">Read the docs</a>
      </div>
      <section class="hero-carousel splide" aria-label="Sealshot app screenshots">
        <div class="splide__track">
          <ul class="splide__list">
            {
              heroSlides.map((slide, i) => (
                <li class="splide__slide">
                  <figure class="hero-slide">
                    <div class="hero-slide-media">
                      <img src={slide.src} alt={slide.alt} loading={i === 0 ? 'eager' : 'lazy'} />
                    </div>
                    <figcaption>
                      <strong>{slide.subtitle}</strong>
                      <span>{slide.description}</span>
                    </figcaption>
                  </figure>
                </li>
              ))
            }
          </ul>
        </div>
      </section>
    </div>
  </section>

  <section class="section" id="features" aria-labelledby="features-heading">
    <div class="wrap">
      <p class="kicker">Features</p>
      <h2 id="features-heading">Everything a capture tool should do</h2>
      <div class="features">
        {
          features.map((f) => (
            <div class="feature">
              <h3>{f.title}</h3>
              <p>{f.body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="workflows-heading">
    <div class="wrap">
      <p class="kicker">Workflows</p>
      <h2 id="workflows-heading">Built for the job in front of you</h2>
      <div class="features workflows">
        <a class="feature workflow-card" href="/docs/workflows/bug-reports/">
          <h3>Report bugs without leaking your stack</h3>
          <p>
            Capture the repro, number the steps, and let Smart Redaction
            catch the keys and tokens before the ticket does.
          </p>
          <span class="workflow-link">See the workflow →</span>
        </a>
        <a class="feature workflow-card" href="/docs/workflows/sensitive-documents/">
          <h3>Share sensitive documents safely</h3>
          <p>
            Document-aware redaction, encryption at rest, and an encrypted
            package with an expiry — passcode over a separate channel.
          </p>
          <span class="workflow-link">See the workflow →</span>
        </a>
        <a class="feature workflow-card" href="/docs/workflows/walkthrough-videos/">
          <h3>Record a walkthrough people can follow</h3>
          <p>
            Narrated screen recording with clean voice audio and keyboard
            pauses — exported as an .mp4 anyone can play.
          </p>
          <span class="workflow-link">See the workflow →</span>
        </a>
      </div>
    </div>
  </section>

  <section class="section alt" aria-labelledby="privacy-heading">
    <div class="wrap">
      <p class="kicker">Privacy</p>
      <h2 id="privacy-heading">Your screen is your business</h2>
      <p class="sub">
        Screenshots routinely contain credentials, customer data, and private
        conversations. Sealshot processes everything — OCR, metadata, search —
        on your Mac. Nothing is uploaded, no account is required, and no
        telemetry is collected.
      </p>
    </div>
  </section>

  <section class="section" aria-labelledby="updates-heading">
    <div class="wrap">
      <p class="kicker">Stay in the loop</p>
      <h2 id="updates-heading">Get Sealshot updates</h2>
      <p class="sub">
        New features, releases, and tips — or watch the
        <a href="/docs/changelog/v0-7-0/">changelog</a>.
      </p>
      <NewsletterForm />
    </div>
  </section>
</SiteLayout>

<script>
  import Splide from '@splidejs/splide';

  new Splide('.hero-carousel', {
    type: 'loop',
    autoplay: true,
    interval: 6000,
    pauseOnHover: true,
    pauseOnFocus: true,
    speed: 500,
    reducedMotion: { speed: 0, rewindSpeed: 0, autoplay: 'pause' },
  }).mount();
</script>
